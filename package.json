{
  "name": "outreach",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.9.0",
  "engines": { "node": ">=22" },
  "scripts": {
    "build": "turbo run build",
    "test": "turbo run test",
    "lint": "turbo run lint",
    "dev": "turbo run dev",
    "db:up": "docker compose up -d",
    "db:migrate": "pnpm --filter @outreach/db exec prisma migrate dev"
  },
  "devDependencies": {
    "turbo": "^2.3.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  }
}
