# apps/api
DATABASE_URL="postgresql://outreach:outreach@localhost:5544/outreach"
ENCRYPTION_KEY="" # base64 of 32 random bytes: openssl rand -base64 32
BETTER_AUTH_SECRET="" # openssl rand -base64 32
BETTER_AUTH_URL="http://localhost:8787"
API_PORT="8787"
WEB_ORIGIN="http://localhost:3000"
LINKEDIN_CLIENT_ID=""
LINKEDIN_CLIENT_SECRET=""
LINKEDIN_REDIRECT_URI="http://localhost:8787/linkedin/callback"
LINKEDIN_API_VERSION="202601"
AI_PROVIDER="openai"
AI_TEXT_MODEL="gpt-4o"
AI_IMAGE_MODEL="gpt-image-2"
OPENAI_API_KEY=""   # required only when AI routes run
# Image generation: OpenAI (gpt-image-2) is on whenever OPENAI_API_KEY is set.
# Set GOOGLE_GENERATIVE_AI_API_KEY to also offer Google "Nano Banana"
# (defaults to gemini-3.1-flash-image; override with AI_IMAGE_MODEL_GOOGLE,
# e.g. gemini-3-pro-image for Nano Banana Pro).
GOOGLE_GENERATIVE_AI_API_KEY=""   # optional — enables the Google · Nano Banana image model
AI_IMAGE_MODEL_GOOGLE=""          # optional Google image model override (default: gemini-3.1-flash-image)
AI_IMAGE_PROVIDER="openai"        # default provider when the user hasn't picked one: openai | google
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_ACCESS_KEY=outreach
S3_SECRET_KEY=outreach-secret
S3_BUCKET=outreach-resources
S3_FORCE_PATH_STYLE=true

# SMTP mailer (optional; empty SMTP_HOST = log fallback)
# SMTP_HOST=""
# SMTP_PORT="587"
# SMTP_SECURE="false"
# SMTP_USER=""
# SMTP_PASS=""
# SMTP_FROM="Outreach <no-reply@localhost>"
